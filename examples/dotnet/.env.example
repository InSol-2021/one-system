# ---------------------------------------------------------------------------
# One System CAS — .NET sample configuration
# Copy to .env and adjust. These map directly onto CasConfig in Program.cs.
# ---------------------------------------------------------------------------

# Internal/back-channel origin of the One System CAS server, used for
# server-to-server token validation (the app/container reaches CAS here).
CAS_BASE_URL=http://localhost:8080

# Public, browser-facing CAS base URL used to build the SSO login redirect
# ({CAS}/sso/login). In split-horizon deployments the browser must reach CAS at
# this public host (e.g. http://161.97.158.202:91), which differs from the
# internal CAS_BASE_URL. Leave empty to fall back to CAS_BASE_URL for local dev.
CAS_PUBLIC_URL=

# The client_id registered with the CAS server for THIS app.
CAS_CLIENT_ID=dotnet-demo

# The client_secret for the registered client (used only server-to-server).
CAS_CLIENT_SECRET=dotnet-demo-secret

# The callback_url REGISTERED with the CAS server for this client.
# The CAS server redirects the browser here with ?token=<JWT> appended.
CAS_CALLBACK_URL=http://localhost:9106/cas/callback

# Port this sample app listens on (assigned: 9106).
PORT=9106

# Path to the SQLite file holding LOCAL username/password accounts. The users
# table is created and seeded (rajan/rajan123, demo/demo123) on first startup.
# Defaults to ./data/app.db next to the app; the Docker image sets /app/data/app.db.
APP_DB_PATH=./data/app.db
