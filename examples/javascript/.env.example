# --- One System CAS configuration for the JavaScript sample ---
# Copy this file to ".env" and fill in the values registered for THIS client app.

# INTERNAL / back-channel origin of the One System CAS server (no trailing slash).
# Used for SERVER-TO-SERVER token validation (POST {CAS_BASE_URL}/api/validate-token).
# In a split-horizon Docker deployment this is the internal url the container can
# reach (e.g. http://one-system-cas).
CAS_BASE_URL=http://localhost:8080

# PUBLIC / browser-facing origin of the One System CAS server (no trailing slash).
# Used to build the {CAS_PUBLIC_URL}/sso/login redirect the user's BROWSER is sent to.
# In a split-horizon Docker deployment this is the public url the browser can reach
# (e.g. http://161.97.158.202:91). Leave empty to fall back to CAS_BASE_URL for
# local single-url development.
CAS_PUBLIC_URL=

# The client_id this sample app is registered under in the CAS server.
CAS_CLIENT_ID=javascript-sample

# The client_secret paired with CAS_CLIENT_ID.
# SECRET: lives ONLY on the backend (this server.js). It is NEVER sent to the browser.
CAS_CLIENT_SECRET=replace-with-your-client-secret

# The callback_url registered for this client in the CAS server.
# The CAS server 302-redirects here with ?token=<jwt> after a successful login.
# Must match the port below and the path served by this sample (/cas/callback).
CAS_CALLBACK_URL=http://localhost:9103/cas/callback

# Port this sample app (Express) listens on.
PORT=9103
