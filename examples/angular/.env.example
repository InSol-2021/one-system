# --- One System CAS configuration for the Angular sample ---
# Copy this file to ".env" and fill in the values registered for THIS client app.
#
# These variables are consumed by the tiny Express backend (server/server.js).
# The backend:
#   1. Serves the built Angular app (dist/) on APP_PORT.
#   2. Exposes POST /api/auth/validate which performs the SERVER-TO-SERVER
#      call to {CAS_BASE_URL}/api/validate-token (adding the client_secret).
#   3. Exposes GET /api/config so the Angular front-end learns the PUBLIC CAS
#      URL (CAS_PUBLIC_URL) + CAS_CLIENT_ID + CAS_CALLBACK_URL at runtime
#      (NO secret is ever sent).

# INTERNAL / back-channel origin of the One System CAS server (no trailing slash).
# Used ONLY for the server-to-server token validation call. In a split-horizon
# deployment this is the address the BACKEND/container reaches CAS on (e.g. the
# internal docker name http://one-system-cas) — it need not be reachable from the
# user's browser.
CAS_BASE_URL=http://localhost:8080

# PUBLIC, browser-facing origin of the CAS server (no trailing slash).
# Shipped to the SPA via GET /api/config as `serverUrl`; the in-browser SDK builds
# the {CAS_PUBLIC_URL}/sso/login redirect from it, so it MUST be reachable from the
# user's browser (e.g. http://161.97.158.202:91). Leave unset to fall back to
# CAS_BASE_URL for single-url local dev.
CAS_PUBLIC_URL=http://localhost:8080

# The client_id this sample app is registered under in the CAS server.
CAS_CLIENT_ID=angular-sample

# The client_secret paired with CAS_CLIENT_ID.
# SECRET: lives ONLY on the backend (server/server.js). NEVER sent to the browser.
CAS_CLIENT_SECRET=replace-with-your-client-secret

# The callback_url registered for this client in the CAS server.
# The CAS server 302-redirects here with ?token=<jwt> after a successful login.
# Must match APP_PORT below and the Angular route path (/cas/callback).
CAS_CALLBACK_URL=http://localhost:9110/cas/callback

# Port this sample app (Express + built Angular) listens on.
APP_PORT=9110

# --- Local accounts (username/password) ---
# The app also has its OWN local accounts, stored in a SQLite file. Two demo
# users are seeded on first startup if the table is empty:
#     rajan / rajan123      demo / demo123
# Optional: override where the SQLite file lives (must be writable at runtime).
# Defaults to <example>/data/app.db. The Docker image sets /app/data/app.db.
# APP_DB_PATH=./data/app.db
