{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "useDefineForClassFields": false,
    "lib": ["ES2022", "dom"]

    // ── CAS SDK dependency ───────────────────────────────────────────────
    // No tsconfig "paths" mapping is needed. `@cas-system/angular-cas-client`
    // is a normal npm dependency (see package.json) resolved from the public
    // registry into node_modules/@cas-system/angular-cas-client. The
    // published package's main/types still point at raw TypeScript
    // (src/index.ts), so Angular compiles it from source exactly as before —
    // see the explicit "include" glob in tsconfig.app.json for that. The
    // only thing that changed is WHERE the source comes from (npm registry
    // download vs. a local file: symlink), not that it's source at all.
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
