# --- One System CAS configuration for the React sample ---
# Copy this file to ".env" and fill in the values registered for THIS client app.
#
#   cp .env.example .env
#
# These variables are read by the Express backend (server.js). The backend
# exposes the NON-secret subset (CAS_PUBLIC_URL, CAS_CLIENT_ID, CAS_CALLBACK_URL)
# to the browser via GET /api/config. The CAS_CLIENT_SECRET NEVER leaves the
# backend -- it is only used in the server-to-server /api/validate-token call.

# INTERNAL / back-channel origin of the One System CAS server (no trailing slash).
# Used ONLY for server-to-server token validation (POST {CAS_BASE_URL}/api/validate-token).
# In a split-horizon deploy this is the internal docker name (e.g. http://one-system-cas).
CAS_BASE_URL=http://localhost:8080

# PUBLIC, browser-facing origin of the CAS server (no trailing slash). The browser
# SDK builds the {CAS_PUBLIC_URL}/sso/login redirect from this, so it must be a host
# the user's browser can reach (e.g. http://161.97.158.202:91). Shipped to the SPA
# via GET /api/config as serverUrl. Leave empty to fall back to CAS_BASE_URL for
# single-url local dev.
CAS_PUBLIC_URL=

# The client_id this sample app is registered under in the CAS server.
CAS_CLIENT_ID=react-sample

# The client_secret paired with CAS_CLIENT_ID.
# SECRET: lives ONLY on the backend (server.js). It is NEVER sent to the browser.
CAS_CLIENT_SECRET=replace-with-your-client-secret

# The callback_url registered for this client in the CAS server.
# The CAS server 302-redirects here with ?token=<jwt> after a successful login.
# Must match the port below. The SPA mounts CasProvider on every route, so any
# path works; we use the app root for simplicity.
CAS_CALLBACK_URL=http://localhost:9107/

# Port this sample app (Express + built SPA, and the Vite dev proxy target) listens on.
PORT=9107

# --- Local account auth (NEW) ---
# This app also has its OWN local username/password accounts (SQLite store) and
# its OWN cookie-based session, in addition to the CAS SSO flow above.

# Secret used to sign the local session cookie (express-session).
# Set a long random value in production.
SESSION_SECRET=replace-with-a-long-random-string

# Path to the SQLite file backing the local user store. Must be writable at
# runtime. Defaults to ./data/app.db; in Docker it is /app/data/app.db.
# Two demo users are seeded on first startup: rajan/rajan123 and demo/demo123.
DB_PATH=./data/app.db
