# Copy this file to ".env" and fill in the values for your registered client.
#   cp .env.example .env

# INTERNAL / back-channel base origin of the One System CAS server (no trailing
# slash needed). Used for SERVER-TO-SERVER calls (token validation, logout). In
# a split-horizon deployment this is the internal host the app container reaches
# (e.g. http://one-system-cas).
CAS_BASE_URL=http://localhost:8080

# PUBLIC / browser-facing base origin of the CAS server, used ONLY to build the
# browser login redirect ({CAS_PUBLIC_URL}/sso/login). The user's browser is
# sent here, so it must be the public host (e.g. http://161.97.158.202:91).
# Leave empty for single-url local dev and it falls back to CAS_BASE_URL.
CAS_PUBLIC_URL=

# The client_id you registered with the CAS server for THIS sample app.
CAS_CLIENT_ID=your_client_id

# The client_secret for that client. SERVER-SIDE ONLY -- never expose to a browser.
CAS_CLIENT_SECRET=your_client_secret

# This MUST exactly match the callback_url registered for the client on the CAS
# server. The CAS server redirects the browser here with ?token=<JWT>.
CAS_CALLBACK_URL=http://localhost:9104/callback

# Port this Flask app listens on. Assigned port for this sample is 9104.
PORT=9104

# Secret used to sign THIS app's own Flask session cookie (unrelated to the CAS
# JWT secret). Change it to a random value for anything beyond local testing.
FLASK_SECRET_KEY=dev-only-change-me

# Path to the local SQLite user store for username/password accounts. Defaults
# to ./data/app.db next to app.py; the Docker image sets this to /app/data/app.db.
# The file and its demo users (rajan/rajan123, demo/demo123) are created on first
# run if the table is empty. This dir must be WRITABLE at runtime.
# APP_DB_PATH=./data/app.db
