# =============================================================================
# Environment for examples/docker-compose.yml (the sample-apps stack).
# Copy to examples/.env and adjust. See ../DEPLOYMENT.md.
# =============================================================================

# --- CAS server URLs (split-horizon aware) -----------------------------------
# CAS_PUBLIC_URL — PUBLIC, browser-facing CAS base. The user's browser is sent
# here for the /sso/login redirect, so it MUST be resolvable from the browser.
#   Real single server : your CAS domain or public IP, e.g. http://203.0.113.10:91
#   Docker Desktop demo : http://host.docker.internal:8000
CAS_PUBLIC_URL=http://host.docker.internal:8000

# CAS_INTERNAL_URL — INTERNAL back-channel base used by the sample CONTAINERS for
# server-to-server token validation. On a single Docker host this is the CAS
# service's container name (e.g. http://one-system-cas). Set it only when it
# differs from CAS_PUBLIC_URL (split-horizon: the browser cannot resolve the
# docker name and the containers cannot hairpin to the public IP). If unset,
# samples fall back to CAS_PUBLIC_URL (fine when one URL reaches both).
# CAS_INTERNAL_URL=http://one-system-cas

# Scheme+host the browser is redirected back to after login. The sample port and
# callback path are appended automatically and must match the seeded callback_url.
#   Local demo  : http://localhost
#   Real server : https://demo.example.com   (drop the per-sample ports if behind a proxy)
SAMPLE_BASE_HOST=http://localhost

# --- DEMO client secrets -----------------------------------------------------
# These MUST match Database\Seeders\SampleClientsSeeder (same plaintext; the CAS
# server stores them hashed). They are well-known placeholders — override every
# one with a strong, unique value for any real deployment, and re-seed.
LARAVEL_CAS_SECRET=demo-secret-laravel
NODEJS_CAS_SECRET=demo-secret-nodejs
JAVASCRIPT_CAS_SECRET=demo-secret-javascript
PYTHON_CAS_SECRET=demo-secret-python
JAVA_CAS_SECRET=demo-secret-java
DOTNET_CAS_SECRET=demo-secret-dotnet
REACT_CAS_SECRET=demo-secret-react
NEXTJS_CAS_SECRET=demo-secret-nextjs
VUE_CAS_SECRET=demo-secret-vue
ANGULAR_CAS_SECRET=demo-secret-angular
RUST_CAS_SECRET=demo-secret-rust
