# ---------------------------------------------------------------------------
# One System CAS — Node.js sample configuration
# Copy this file to ".env" and fill in the values registered with the CAS server.
# ---------------------------------------------------------------------------

# INTERNAL / back-channel origin of the One System CAS server (no trailing slash).
# Used for server-to-server token validation (POST /api/validate-token). In the
# split-horizon deployment this is the internal docker name the container reaches
# (e.g. http://one-system-cas), which the browser cannot resolve.
CAS_BASE_URL=http://localhost:8080

# PUBLIC, browser-facing origin of the CAS server (no trailing slash).
# Used ONLY to build the {CAS}/sso/login redirect the user's browser is sent to
# (e.g. http://161.97.158.202:91). Leave unset for single-url local dev, in which
# case the login redirect falls back to CAS_BASE_URL.
CAS_PUBLIC_URL=

# Credentials registered for THIS client app on the CAS server.
CAS_CLIENT_ID=your_client_id
CAS_CLIENT_SECRET=your_client_secret

# Must EXACTLY match the callback_url registered for this client on the CAS server.
# For this sample (port 9102) that is:
CAS_CALLBACK_URL=http://localhost:9102/callback

# Port this sample app listens on (assigned: 9102).
PORT=9102

# Secret used to sign this app's OWN session cookie (NOT the CAS JWT secret).
SESSION_SECRET=change-me-in-production

# ---------------------------------------------------------------------------
# Local account store (SQLite).
# Path to the SQLite file backing the app's OWN username/password accounts.
# Defaults to ./data/app.db when unset. Must be writable at runtime.
# On first run the app seeds two demo accounts:
#     rajan / rajan123      demo / demo123
# ---------------------------------------------------------------------------
DB_PATH=./data/app.db
