# One System CAS - Java sample environment
# Copy to .env and adjust. These are read by application.properties as
# ${ENV_VAR:default}. When running with plain `mvn spring-boot:run`, export them
# into your shell (e.g. `set -a; . ./.env; set +a`) or pass with `-D...`.
# When running with Docker, pass via `docker run --env-file .env`.

# INTERNAL back-channel CAS origin (no trailing slash). Used for server-to-server
# token validation. In Docker this is the internal service name (e.g.
# http://one-system-cas) that the app container can reach.
CAS_BASE_URL=http://localhost:8080

# PUBLIC, browser-facing CAS origin (no trailing slash). Used ONLY to build the
# /sso/login redirect the user's BROWSER follows (e.g. http://161.97.158.202:91).
# Leave unset to fall back to CAS_BASE_URL for single-url local dev.
# CAS_PUBLIC_URL=http://localhost:8080

# The client registered on the CAS server for this app.
CAS_CLIENT_ID=java-sample
CAS_CLIENT_SECRET=changeme-client-secret

# Must match the callback_url registered for this client on the CAS server.
CAS_CALLBACK_URL=http://localhost:9105/callback

# Port this sample listens on.
APP_PORT=9105

# Local user store (SQLite) JDBC URL. The file's directory must be writable.
# Default (relative to the working dir): jdbc:sqlite:./data/app.db
# APP_DB_URL=jdbc:sqlite:./data/app.db
