# ---------------------------------------------------------------------------
# Laravel app
# ---------------------------------------------------------------------------
APP_NAME="One System CAS Laravel Sample"
APP_ENV=local
APP_DEBUG=true
# Generate with: php artisan key:generate
APP_KEY=

# This app's public URL. The assigned port for this sample is 9101.
APP_URL=http://localhost:9101

# File-based session/cache keep the CAS flow self-contained.
SESSION_DRIVER=file
CACHE_STORE=file
LOG_CHANNEL=stderr
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Local username/password store (SQLite)
# ---------------------------------------------------------------------------
# Used by App\Support\LocalUserStore so a visitor can sign in with a local
# account in addition to CAS. The file is created + seeded on first run with
# two demo users:  rajan / rajan123   and   demo / demo123.
DB_CONNECTION=sqlite
# Defaults to database/app.db inside the app; override to relocate the file.
# DB_DATABASE=/app/data/app.db

# ---------------------------------------------------------------------------
# One System CAS client  (read by cas-system/laravel-client)
# ---------------------------------------------------------------------------
# INTERNAL back-channel CAS origin — used for SERVER-TO-SERVER token validation
# (this app's container -> CAS). The task calls this CAS_BASE_URL; the package
# env key is CAS_SERVER_URL. Keep them identical (the internal value).
CAS_BASE_URL=http://localhost:8001
CAS_SERVER_URL=http://localhost:8001

# PUBLIC, browser-facing CAS origin — used ONLY for the /sso/login redirect the
# user's BROWSER is sent to. In a split-horizon deployment the browser cannot
# reach the internal host above, so set this to the public CAS URL
# (e.g. http://161.97.158.202:91). Leave empty to fall back to CAS_SERVER_URL
# for local single-url development.
CAS_PUBLIC_URL=http://localhost:8001

# Credentials registered for THIS client app in the CAS server.
CAS_CLIENT_ID=your_client_id
CAS_CLIENT_SECRET=your_client_secret

# Must EXACTLY match the callback_url registered for this client in the CAS server.
CAS_CALLBACK_URL=http://localhost:9101/callback

# Optional: turn on HMAC request signing if your CAS server requires it.
CAS_ENABLE_SIGNATURE_VALIDATION=false
# CAS_SIGNATURE_SECRET=your-256-bit-signature-secret

# This sample is DB-free: keep local user creation off.
CAS_CREATE_LOCAL_USERS=false
# We define our own routes, so disable the package's auto /cas/* routes.
CAS_ROUTES_ENABLED=false
