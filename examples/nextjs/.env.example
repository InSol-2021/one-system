# ---------------------------------------------------------------------------
# One System CAS — Next.js sample configuration
# Copy this file to ".env.local" and fill in the values registered for your
# client app on the CAS server.
#
#   cp .env.example .env.local
# ---------------------------------------------------------------------------

# INTERNAL back-channel base URL of the One System CAS server. No trailing slash.
# Used for SERVER-TO-SERVER token validation (POST /api/validate-token) and the
# server-side callback handler. In a split-horizon deploy this is the value the
# app container can reach (e.g. the internal docker service name http://one-system-cas).
CAS_SERVER_URL=http://localhost:8080

# PUBLIC, browser-facing base URL of the CAS server. No trailing slash.
# The package middleware uses this to build the /sso/login redirect that the
# USER'S BROWSER is sent to, so it must be reachable from the browser (e.g. the
# public host http://161.97.158.202:91). If unset, falls back to CAS_SERVER_URL
# (so single-url local dev still works unchanged).
CAS_PUBLIC_URL=http://localhost:8080

# The client_id registered for THIS app on the CAS server.
CAS_CLIENT_ID=nextjs-sample

# The client_secret for THIS app. SERVER-SIDE ONLY — never exposed to the
# browser. Used for the server-to-server POST /api/validate-token call AND
# (by default) for signing the app's own session cookie.
CAS_CLIENT_SECRET=replace-with-your-client-secret

# The callback URL registered on the CAS server for this client. After the
# user authenticates, the CAS server redirects the browser here with ?token=.
# Must match exactly what is registered and must point at this app's port.
CAS_CALLBACK_URL=http://localhost:9108/api/cas/callback

# Optional dedicated secret used to sign the app's HttpOnly session cookie.
# If omitted, the package falls back to CAS_CLIENT_SECRET.
# CAS_COOKIE_SECRET=replace-with-a-long-random-string

# Port this Next.js app listens on (the npm scripts already pass -p 9108).
PORT=9108

# ---------------------------------------------------------------------------
# LOCAL ACCOUNTS (the app's own username/password store)
# In addition to CAS SSO, the app has its own local accounts in a SQLite file.
# On first startup two demo users are seeded (if the table is empty):
#     rajan / rajan123      demo / demo123
# Visit /login to sign in with a local account.
# ---------------------------------------------------------------------------

# Path to the SQLite user-store file. Defaults to ./data/app.db (relative to the
# process working dir). The Docker image sets this to /app/data/app.db.
# APP_DB_PATH=./data/app.db

# ---------------------------------------------------------------------------
# PUBLIC values (NEXT_PUBLIC_*) — safe to ship to the browser.
# The client-side <CasProvider> builds the SSO login redirect URL from these.
# They contain NO secret (the client_secret is NEVER exposed to the browser).
# ---------------------------------------------------------------------------
# Browser-facing CAS base URL the in-browser SDK uses for the /sso/login
# redirect. MUST be the PUBLIC host (set it to the same value as CAS_PUBLIC_URL).
# If unset, the provider falls back to nothing client-side, so keep it in sync.
NEXT_PUBLIC_CAS_PUBLIC_URL=http://localhost:8080
NEXT_PUBLIC_CAS_CLIENT_ID=nextjs-sample
NEXT_PUBLIC_CAS_CALLBACK_URL=http://localhost:9108/api/cas/callback
