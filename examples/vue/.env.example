# ---------------------------------------------------------------------------
# Vue CAS client sample — environment configuration.
# Copy this file to `.env` and fill in the values registered on the CAS server.
# ---------------------------------------------------------------------------

# INTERNAL back-channel origin of the One System CAS server (no trailing slash).
# Used for SERVER-TO-SERVER token validation (this backend -> CAS). In a
# split-horizon deployment this is the address the app container can reach
# (e.g. the internal docker name http://one-system-cas).
CAS_BASE_URL=http://localhost:8080

# PUBLIC, browser-facing origin of the CAS server (no trailing slash). Used to
# build the in-browser login redirect ({CAS_PUBLIC_URL}/sso/login) — the browser
# must reach CAS at this PUBLIC address (e.g. http://161.97.158.202:91).
# Leave empty to fall back to CAS_BASE_URL for single-url local dev.
CAS_PUBLIC_URL=http://localhost:8080

# The client_id registered for THIS sample on the CAS server.
CAS_CLIENT_ID=vue-sample-app

# The client_secret for the client_id above. SERVER-SIDE ONLY — never exposed
# to the browser. Used by the Express backend to call /api/validate-token.
CAS_CLIENT_SECRET=replace-with-your-client-secret

# The callback URL registered for this client on the CAS server. The CAS server
# redirects the browser here with ?token=<jwt> after login.
CAS_CALLBACK_URL=http://localhost:9109/auth/callback

# Port this sample listens on (Express serves both the SPA and the API here).
APP_PORT=9109

# ---------------------------------------------------------------------------
# Local accounts (the app's OWN username/password auth, stored in SQLite).
# ---------------------------------------------------------------------------

# Secret used to sign the local session cookie. Set a strong random value in
# production. (Falls back to an insecure dev default if unset.)
SESSION_SECRET=replace-with-a-long-random-string

# Optional: override where the SQLite user store lives. Defaults to ./data/app.db
# (relative to the sample). The directory must be writable at runtime.
# APP_DB_PATH=/app/examples/vue/data/app.db

# ---------------------------------------------------------------------------
# Front-end (Vite) values. The secret is intentionally absent — only PUBLIC
# values are exposed to the browser. (Vite only exposes variables prefixed with
# VITE_ to client code, and inlines them at BUILD time.)
#
# NOTE: at runtime the SPA prefers the PUBLIC config served by the backend at
# GET /api/auth/config (sourced from CAS_PUBLIC_URL above). These VITE_* values
# are only a fallback for standalone `vite` dev where there is no backend, so
# VITE_CAS_BASE_URL here should point at the browser-reachable CAS URL.
# ---------------------------------------------------------------------------
VITE_CAS_BASE_URL=http://localhost:8080
VITE_CAS_CLIENT_ID=vue-sample-app
VITE_CAS_CALLBACK_URL=http://localhost:9109/auth/callback
