# ---------------------------------------------------------------------------
# One System CAS — Rust / axum sample configuration
# Copy this file to ".env" and fill in the values registered with the CAS server.
# ---------------------------------------------------------------------------

# INTERNAL back-channel origin of the One System CAS server, used for the
# SERVER-TO-SERVER token validation call (no trailing slash). In the docker
# deployment this is the internal host, e.g. http://one-system-cas. The browser
# never uses this value. CAS_SERVER_URL is accepted too.
CAS_BASE_URL=http://localhost:8000

# PUBLIC, browser-facing origin of the CAS server, used to build the
# {CAS}/sso/login redirect the user's browser is sent to (no trailing slash).
# In the split-horizon docker deployment this is the public host, e.g.
# http://161.97.158.202:91. Leave empty to fall back to CAS_BASE_URL (local
# single-url dev).
CAS_PUBLIC_URL=

# Credentials registered for THIS client app on the CAS server.
CAS_CLIENT_ID=rust-sample
CAS_CLIENT_SECRET=demo-secret-rust

# Must EXACTLY match the callback_url registered for this client on the CAS
# server. For this sample (port 9111) the callback path is /cas/callback:
CAS_CALLBACK_URL=http://localhost:9111/cas/callback

# Port this sample app listens on (assigned: 9111).
PORT=9111

# Path to the local SQLite user store (created + seeded on startup).
APP_DB_PATH=./data/app.db
